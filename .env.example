# 通用 AI API Key，建议所有 OpenAI 兼容接口都填写这里
AI_API_KEY="YOUR_GLM_API_KEY"

# 兼容旧版 Gemini 配置的备用 Key，不用可以留空
GEMINI_API_KEY=""

# OpenAI 兼容接口的基础地址
# 当前示例使用中国区 GLM Coding Plan 地址
# 代码会自动补全 /chat/completions
GEMINIBASE_URL="https://open.bigmodel.cn/api/coding/paas/v4"

# 分析代码时使用的模型名称
AI_MODEL="GLM-5"

# 快速分析模型
# 适合项目画像、入口文件验证、函数文件猜测等轻量任务
AI_MODEL_FAST="GLM-5-Flash"

# 项目画像阶段模型
AI_MODEL_PROJECT="GLM-5-Flash"

# 入口文件研判阶段模型
AI_MODEL_ENTRY="GLM-5-Flash"

# 函数文件猜测阶段模型
AI_MODEL_FILE_GUESS="GLM-5-Flash"

# 关键函数分析阶段模型
AI_MODEL_FUNCTION="GLM-5"

# 是否启用流式响应
# 建议保持 true，可更早看到模型返回并减少等待体感
AI_USE_STREAM="true"

# 是否启用 Thinking
# 若当前模型与端点支持推理增强，开启后通常能提升分析质量
AI_ENABLE_THINKING="false"

# 单次 AI 请求最大输出 token
AI_MAX_OUTPUT_TOKENS="2000"

# 单次 AI 请求超时时间（毫秒）
AI_REQUEST_TIMEOUT_MS="60000"

# 关键子函数继续下钻分析的最大递归深度
# 数值越大，请求次数和耗时越高
AI_MAX_RECURSION_DEPTH="2"

# 候选入口文件最多研判几个
# 默认 3，通常已经足够
AI_MAX_ENTRY_FILE_CANDIDATES="3"

# 每一层最多继续下钻几个函数
# 默认 3，能明显减少小项目分析耗时
AI_MAX_DRILLDOWN_PER_LEVEL="3"

# 单次完整分析最多展开多少个函数节点
# 用于防止递归分析在中大型项目中失控
AI_MAX_ANALYSIS_NODES="12"

# 在调用 AI 猜文件前，先启发式扫描多少个高优先级文件
AI_MAX_HEURISTIC_SEARCH_FILES="24"

# 项目级正则搜索最多扫描多少个文件
AI_MAX_PROJECT_SEARCH_FILES="80"

# 后台预热函数索引时最多扫描多少个文件
AI_MAX_INDEX_FILES="48"

# 后台预热函数索引的并发数
AI_INDEX_CONCURRENCY="4"

# 当前应用自己的访问地址
APP_URL="http://localhost:3000"
