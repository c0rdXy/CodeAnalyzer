# 通用 AI API Key，推荐所有 OpenAI 兼容接口都填写这里。
# 这里请填写你的智谱 GLM API Key。
AI_API_KEY="YOUR_GLM_API_KEY"

# 兼容旧版 Gemini 配置的备用 Key。
# 当前使用 GLM 时可留空。
GEMINI_API_KEY=""

# OpenAI 兼容接口的基础地址。
# 当前示例使用中国区 GLM Coding Plan 专属地址。
# 代码会自动补上 /chat/completions。
GEMINIBASE_URL="https://open.bigmodel.cn/api/coding/paas/v4"

# 分析代码时使用的模型名称。
# 当前示例使用 GLM-5。
AI_MODEL="GLM-5"

# 关键子函数继续下钻分析的最大递归深度。
# 默认建议为 2，数值越大，请求次数和耗时越高。
AI_MAX_RECURSION_DEPTH="2"

# 当前应用自己的访问地址。
# 如果只是本地开发，通常填写本地 Vite 地址即可。
APP_URL="http://localhost:3000"
